{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "2.2.26",
  "default_locale": "en",
  "icons": {
    "128": "Icon.png",
    "16": "Icon.png",
    "48": "Icon.png"
  },
  "permissions": ["contextMenus", "storage", "downloads", "webRequest"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "Icon.png",
      "16": "Icon.png",
      "48": "Icon.png"
    },
    "default_title": "__MSG_extensionName__"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "js": ["shared.js", "content.js"],
      "matches": [
        "https://www.instagram.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["muted.png", "unmuted.png", "page-download-bridge.js"],
      "matches": ["https://www.instagram.com/*"]
    }
  ],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "key": ""
}
